{
	/// WOG New Age — Power Stones (option 196)
	/// Collectible map objects that permanently increase a hero's primary skill by 1.
	/// Disappear after the first hero picks them up (removable pickup style).
	///
	/// Visual: reuse ZCBON gem sprites from wake-of-gods.Commanders (dependency).
	/// ZCBON001 = ruby (red)    → Attack
	/// ZCBON002 = sapphire (blue) → Defense
	/// ZCBON000 = opal (purple) → Spell Power
	/// ZCBON003 = emerald (green) → Knowledge

	"wogPowerStoneAttack" : {
		"handler" : "configurable",
		"base" : {
			"blockedVisitable" : true,
			"removable" : true,
			"sounds" : {
				"ambient" : ["LOOPCAMP"],
				"visit"   : ["EXPERNCE"],
				"removal" : ["PICKUP01", "PICKUP02", "PICKUP03", "PICKUP04", "PICKUP05", "PICKUP06", "PICKUP07"]
			}
		},
		"types" : {
			"wogPowerStoneAttack" : {
				"aiValue" : 1500,
				"rmg" : {
					"zoneLimit" : 2,
					"value"     : 1500,
					"rarity"    : 60
				},
				"templates" : {
					"zcbon001" : {
						"animation" : "objects/zcbon001.def",
						"mask" : ["VV", "VA"],
						"visitableFrom" : ["+++", "+++", "+++"]
					}
				},
				"visitMode"  : "unlimited",
				"selectMode" : "selectFirst",
				"onEmptyMessage" : "The ruby stone's power has already been claimed.",
				"rewards" : [
					{
						"appearChance"  : { "min" : 0, "max" : 100 },
						"message"       : "You find a blood-red stone glowing with fierce energy. As you touch it, your muscles surge with new strength! Your Attack increases by 1.",
						"removeObject"  : true,
						"primary"       : { "attack" : 1 }
					}
				]
			}
		}
	},

